# Supabase Postgres (Settings -> Database -> Connection string in Supabase dashboard)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Path to Firebase service account JSON (for token verification + FCM)
FIREBASE_CREDENTIALS_PATH=path/to/serviceAccountKey.json
GOOGLE_SERVICE_PATH=path/to/google-services.json

# CORS origins for web dashboard (comma-separated; use * for dev)
CORS_ORIGINS=["*"]

# Rate limit: requests per minute per IP (default 100)
RATE_LIMIT_PER_MINUTE=100

